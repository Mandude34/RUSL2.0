# ===== COMMON (Both Services) =====
PORT=3000
NODE_ENV=production

# ===== REQUIRED FOR BOTH SERVICES =====
# Database connection string (get from Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== API SERVER ONLY =====
# Clerk authentication (get from https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_live_...

# Optional: OpenAI integration for predictions
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ===== FRONTEND (FLOWSTOCK) - BUILD TIME =====
# These are read DURING build, not at runtime
BASE_PATH=/
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Optional: Proxy Clerk requests through API server
# VITE_CLERK_PROXY_URL=/api/__clerk

# ===== DO NOT SET ON RAILWAY =====
# REPL_ID=  (Replit-specific, breaks Vite plugins on Railway)
